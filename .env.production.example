POSTGRES_DB=semantix
POSTGRES_MIGRATION_USER=semantix_migrator
POSTGRES_MIGRATION_PASSWORD=replace-with-a-long-random-migration-password
POSTGRES_RUNTIME_USER=semantix_runtime
POSTGRES_RUNTIME_PASSWORD=replace-with-a-different-long-random-runtime-password

EMBEDDING_PROVIDER=mock
GENERATION_PROVIDER=mock
MOCK_EMBEDDING_DIMENSIONS=384
HF_API_KEY=

AUTH_PRINCIPALS=[{"name":"admin","token_sha256":"replace-with-sha256-hex","role":"admin","namespaces":["*"]}]
ALLOWED_ORIGINS=["https://semantix.example.com"]
TRUSTED_PROXY_CIDRS=["172.28.0.0/24"]
MAX_REQUEST_BODY_BYTES=65536
RATE_LIMIT=20/minute
LOG_LEVEL=INFO

SEMANTIX_BIND_ADDRESS=127.0.0.1
SEMANTIX_PORT=8080
